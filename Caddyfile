{$DOMAIN:localhost} {
	# Auth is handled by backend cookie-based admin access (ADMIN_SECRET)
	# No basicauth — dashboard is publicly readable, mutations require admin cookie

	# API routes (must be before frontend catch-all)
	handle /api/* {
		reverse_proxy backend:8000 {
			transport http {
				response_header_timeout 120s
				dial_timeout 10s
			}
		}
	}

	# Frontend (catch-all)
	handle {
		reverse_proxy frontend:3000
	}
}
