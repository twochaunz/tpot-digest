{$DOMAIN:localhost} {
	encode gzip

	# API routes (must be before frontend catch-all)
	handle /api/* {
		reverse_proxy backend:8000 {
			transport http {
				response_header_timeout 120s
				dial_timeout 10s
			}
		}
	}

	@socialPreview {
		path_regexp ^/app/(?:[0-9]{8}|[0-9]{4}-[0-9]{2}-[0-9]{2})/[0-9]+$
		header_regexp User-Agent (?i)(Twitterbot|facebookexternalhit|Facebot|Slackbot|Discordbot|LinkedInBot|WhatsApp|TelegramBot|Applebot|Googlebot|bingbot)
	}
	handle @socialPreview {
		reverse_proxy backend:8000
	}

	# Frontend (catch-all)
	handle {
		reverse_proxy frontend:3000

		# Hashed static assets: cache forever (new deploys = new hashes)
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# HTML: always revalidate so users get latest deploy
		@html path *.html /
		header @html Cache-Control "no-cache"
	}
}
